PORT=3000

# Default false: POST /ingest tidak akan broadcast sampai Anda set true (middleware siap).
INGEST_ENABLED=false

# Set true saat middleware Anda akan mengirim insiden nyata
# INGEST_ENABLED=true

# ADMIN_SECRET=long-random-for-dashboard-key-management
# INGEST_TOKEN=legacy-shared-secret
# API_KEYS_FILE=./data/api-keys.json
