# Threat map uses Apache ECharts (no Google Maps API key).

# Socket.io bridge (cyber-attack-map-server)
# VITE_SOCKET_URL=http://localhost:3000

# Optional: same as ADMIN_SECRET on the bridge — used to load incidents from MongoDB (GET /admin/incidents/*).
# If unset, the dashboard uses the admin secret saved in Settings (localStorage).
# VITE_BRIDGE_ADMIN_SECRET=

# Only for local UI work without a running bridge — leave unset in production
# VITE_SOCKET_DISABLED=false

# Checkpoint-style simulated source → target traffic on map + feed (no browser notifications for demo ids)
# VITE_DEMO_ATTACKS=false

# Google Gemini (Threat assistant chat on Monitoring — optional)
# VITE_GEMINI_API_KEY=
# Optional model id (default: gemini-2.0-flash)
# VITE_GEMINI_MODEL=gemini-2.0-flash

# UI only connects if GET /health returns version 2 (cyber-attack-map-server terbaru)
